bash scripts/check-unused-i18n-keys.sh

# Check for unused styles in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.tsx' '*.ts' | grep -v 'node_modules')
if [ -n "$STAGED_FILES" ]; then
  npx eslint --no-warn-ignored --rule '{"react-native/no-unused-styles": "error", "unused-imports/no-unused-imports": "error"}' $STAGED_FILES
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Commit blocked: unused styles or unused imports detected. Remove them before committing."
    exit 1
  fi
fi
